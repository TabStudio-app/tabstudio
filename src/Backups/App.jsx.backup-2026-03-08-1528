// Frets: allow blank, 0–24
function clampFret(text) {
  if (text === "") return "";
  const n = Number(text);
  if (!Number.isFinite(n)) return "";
  if (n < 0) return "0";
  if (n > 24) return "24";
  return String(n);
}

function makeBlankGrid(rows, cols) {
