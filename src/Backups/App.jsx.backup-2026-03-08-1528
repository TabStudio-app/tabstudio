  function requestDeleteLibraryAlbum(artistName, album) {
    if (!artistName || !album || album === NO_ALBUM_NAME) return;
    setLibraryDeleteConfirmTarget({
      type: "album",
      artistName,
      album,
      stage: "idle",
      remaining: LIBRARY_DELETE_WAIT_SECONDS,
